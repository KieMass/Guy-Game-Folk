## Copy this file to keystore.properties (git-ignored) and fill in your own
## release keystore details to enable signed release builds. Without this
## file, `gradlew assembleRelease` / `bundleRelease` still work but produce
## an UNSIGNED build that Play Console will reject.
##
## Generate a keystore with:
##   keytool -genkeypair -v -keystore my-release.jks -alias myalias \
##     -keyalg RSA -keysize 2048 -validity 10000

storeFile=/absolute/path/to/your-release.jks
storePassword=your-store-password
keyAlias=your-key-alias
keyPassword=your-key-password
